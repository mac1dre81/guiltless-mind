<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:app="http://schemas.android.com/apk/res-auto">
    <PreferenceCategory app:title="Display">
        <SwitchPreferenceCompat
            app:key="dark_mode"
            app:title="Dark Mode"
            app:summary="Enable dark theme"
            app:defaultValue="false" />
        <ListPreference
            app:key="font_size"
            app:title="Font Size"
            app:useSimpleSummaryProvider="true"
            app:entries="@array/font_size_entries"
            app:entryValues="@array/font_size_values"
            app:defaultValue="16" />
    </PreferenceCategory>
    <PreferenceCategory app:title="Editor">
        <SwitchPreferenceCompat
            app:key="auto_save"
            app:title="Auto-Save"
            app:summary="Automatically save documents while editing"
            app:defaultValue="true" />
    </PreferenceCategory>
</PreferenceScreen>
