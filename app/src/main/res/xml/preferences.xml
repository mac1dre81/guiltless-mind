<?xml version="1.0" encoding="utf-8" ?>
<PreferenceScreen xmlns:app="http://schemas.android.com/apk/res-auto">
    <PreferenceCategory app:title="@string/settings_display_title">
        <SwitchPreferenceCompat
            app:key="dark_mode"
            app:title="@string/settings_dark_mode"
            app:summary="@string/settings_dark_mode_summary"
            app:defaultValue="false"
            app:persistent="false"
        />
        <ListPreference
            app:key="font_size"
            app:title="@string/settings_font_size"
            app:useSimpleSummaryProvider="true"
            app:entries="@array/font_size_entries"
            app:entryValues="@array/font_size_values"
            app:defaultValue="16"
        />
    </PreferenceCategory>
    <PreferenceCategory app:title="@string/settings_editor_title">
        <SwitchPreferenceCompat
            app:key="auto_save"
            app:title="@string/settings_auto_save"
            app:summary="@string/settings_auto_save_summary"
            app:defaultValue="true"
        />
    </PreferenceCategory>
    <PreferenceCategory app:title="@string/settings_help_title">
        <Preference
            app:key="help_pricing"
            app:title="@string/settings_help_pricing_title"
            app:summary="@string/settings_help_pricing_summary"
        />
    </PreferenceCategory>
</PreferenceScreen>
